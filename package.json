{
  "name": "workforce-portal-erik-mota",
  "version": "1.0.0",
  "type": "module",
  "description": "A portal for users to find and register for available job-related activities.",
  "scripts": {
    "start": "node dist/server.js",
    "build:frontend": "ng build",
    "build:backend": "tsc -p tsconfig.server.json",
    "build": "npm run build:frontend && npm run build:backend",
    "serve": "ng serve",
    "dev": "ng serve --port 3000 --host 0.0.0.0 --disable-host-check",
    "cap:sync": "npm run build:frontend && npx cap sync",
    "lint": "tsc --noEmit -p tsconfig.app.json",
    "cap:android": "npx cap run android",
    "cap:ios": "npx cap run ios"
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@google/genai": "^1.43.0",
    "@prisma/client": "^7.4.2",
    "@supabase/supabase-js": "^2.99.0",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "prisma": "^7.4.2",
    "rxjs": "^7.8.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.17",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.9.2"
  }
}
